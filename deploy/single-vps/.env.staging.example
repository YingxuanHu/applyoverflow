# Copy to deploy/single-vps/.env.staging on the VPS.
# Do not commit the real file.
#
# Staging is developer-facing. It must use its own database and should use
# a separate storage bucket from production whenever upload flows are tested.

APP_ENV="staging"
APP_DOMAIN="dev.applyoverflow.com"
STAGING_WEB_PORT="3001"
STAGING_POSTGRES_PORT="5433"

# Local staging Postgres container.
POSTGRES_IMAGE="postgres:18-bookworm"
POSTGRES_DB="autoapplication_staging"
POSTGRES_USER="autoapplication_staging"
POSTGRES_PASSWORD="CHANGE_ME_LONG_RANDOM_STAGING_PASSWORD"
DATABASE_URL="postgresql://autoapplication_staging:CHANGE_ME_LONG_RANDOM_STAGING_PASSWORD@postgres-staging:5432/autoapplication_staging?schema=public"
DATABASE_URL_FOR_BACKUP="postgresql://autoapplication_staging:CHANGE_ME_LONG_RANDOM_STAGING_PASSWORD@postgres-staging:5432/autoapplication_staging?schema=public"
DATABASE_URL_FOR_RESTORE="postgresql://autoapplication_staging:CHANGE_ME_LONG_RANDOM_STAGING_PASSWORD@postgres-staging:5432/autoapplication_staging?schema=public"
DATABASE_PREFER_PRIVATE_FOR_WORKERS="false"
DATABASE_POOL_MAX_WEB="2"
DATABASE_POOL_MAX_DAEMON="2"
DATABASE_POOL_MAX_RECOVERY_POLL="1"
DATABASE_POOL_MAX_OTHER="1"

DISABLE_INGEST_DAEMON="1"
NODE_ENV="production"
LIFECYCLE_PROFILE="balanced"

# Auth URLs for staging.
BETTER_AUTH_SECRET="CHANGE_ME_WITH_OPENSSL_RAND_HEX_32"
BETTER_AUTH_URL="https://dev.applyoverflow.com"
NEXT_PUBLIC_BETTER_AUTH_URL="https://dev.applyoverflow.com"

# Use a separate staging bucket if upload or generated-document flows are tested.
STORAGE_PROVIDER=""
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_FORCE_PATH_STYLE="false"

DB_BACKUP_STORAGE_PREFIX="database-backups/staging"
DB_BACKUP_RETENTION_DAYS="7"
DB_BACKUP_KEEP_LOCAL="0"
DB_RESTORE_SOURCE_DATABASE_NAME=""

# AI and mail. Staging can use the same providers, but separate mail sender
# credentials are safer if you test user flows.
OPENAI_API_KEY=""
OPENAI_STANDARD_MODEL="gpt-4.1-mini"
OPENAI_REASONING_MODEL="gpt-5-mini"
OPENAI_FAST_MODEL="gpt-4o-mini"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

INGESTION_CRON_SECRET=""
TRACKER_CRON_SECRET=""

# Source credentials. Copy only what staging needs.
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
USAJOBS_API_KEY=""
USAJOBS_EMAIL=""
COMPANIES_HOUSE_API_KEY=""
OPENCORPORATES_API_TOKEN=""
GITHUB_FRONTIER_TOKEN=""
GITHUB_FRONTIER_API_VERSION="2022-11-28"
SEC_FRONTIER_USER_AGENT="applyoverflow-staging/1.0 frontier-seed"

# Keep weak aggregators disabled in staging unless deliberately testing them.
JOOBLE_API_KEY=""
JOOBLE_ENABLED="false"
SOURCE_JOOBLE_ENABLED="false"
INGEST_JOOBLE_ENABLED="false"
INGEST_ALLOW_JOOBLE="false"

ADZUNA_ENABLED="false"
JOBICY_ENABLED="true"
REMOTIVE_ENABLED="true"
THEMUSE_ENABLED="true"
USAJOBS_ENABLED="true"
WEWORKREMOTELY_ENABLED="true"

# Limited staging ingestion. Production remains the full fresh job source.
INGEST_GROWTH_MODE="0"
INGEST_SKIP_GENERIC_COMPANY_SITE_POLLS="true"
INGEST_CAPACITY_SCALE="0.25"
INGEST_SOURCE_POLL_CONCURRENCY="2"
INGEST_STEADY_DISCOVERY_LIMIT="4"
INGEST_STEADY_VALIDATION_LIMIT="8"
INGEST_STEADY_SOURCE_POLL_LIMIT="16"
INGEST_STEADY_REDISCOVERY_LIMIT="2"
INGEST_STEADY_URL_HEALTH_LIMIT="1"
INGEST_BURST_DISCOVERY_LIMIT="4"
INGEST_BURST_VALIDATION_LIMIT="8"
INGEST_BURST_SOURCE_POLL_LIMIT="20"
INGEST_BURST_REDISCOVERY_LIMIT="2"
INGEST_BURST_URL_HEALTH_LIMIT="1"
RECOVERY_WORKER_SOURCE_POLL_LIMIT="20"

ADZUNA_COUNTRIES="ca,us"
ADZUNA_ALLOW_NON_NA="false"
ASHBY_ORG_TOKENS=""
GREENHOUSE_BOARD_TOKENS=""
HIMALAYAS_SOURCES="global"
ICIMS_PORTAL_TOKENS=""
JOBICY_TAGS=""
LEVER_SITE_TOKENS=""
RECRUITEE_COMPANY_TOKENS=""
RIPPLING_BOARD_TOKENS=""
SMARTRECRUITERS_COMPANY_TOKENS=""
SUCCESSFACTORS_DOMAIN_TOKENS=""
TALEO_SOURCE_TOKENS=""
THEMUSE_CATEGORIES=""
THEMUSE_LOCATIONS=""
USAJOBS_KEYWORDS=""
WORKABLE_ACCOUNT_TOKENS=""
WORKDAY_SOURCE_TOKENS=""
