# Copy to deploy/single-vps/.env.production on the VPS.
# Do not commit the real file.

# Public web entrypoint. Use ":80" before DNS is ready, then your real domain.
APP_DOMAIN=":80"

# Local Postgres container. Keep this password long and URL-safe, or URL-encode
# it in DATABASE_URL if it contains special characters.
POSTGRES_IMAGE="postgres:18-bookworm"
POSTGRES_DB="autoapplication"
POSTGRES_USER="autoapplication"
POSTGRES_PASSWORD="CHANGE_ME_LONG_RANDOM_PASSWORD"
DATABASE_URL="postgresql://autoapplication:CHANGE_ME_LONG_RANDOM_PASSWORD@postgres:5432/autoapplication?schema=public"
DATABASE_URL_FOR_BACKUP="postgresql://autoapplication:CHANGE_ME_LONG_RANDOM_PASSWORD@postgres:5432/autoapplication?schema=public"
DATABASE_URL_FOR_RESTORE="postgresql://autoapplication:CHANGE_ME_LONG_RANDOM_PASSWORD@postgres:5432/autoapplication?schema=public"
DATABASE_PREFER_PRIVATE_FOR_WORKERS="false"
DATABASE_POOL_MAX_WEB="4"
DATABASE_POOL_MAX_DAEMON="4"
DATABASE_POOL_MAX_RECOVERY_POLL="3"
DATABASE_POOL_MAX_OTHER="2"

# Web process must never spawn ingestion. The worker service runs PM2 directly.
DISABLE_INGEST_DAEMON="1"
NODE_ENV="production"
LIFECYCLE_PROFILE="balanced"

# Auth URLs. Set these to https://your-domain after DNS is pointed at Caddy.
BETTER_AUTH_SECRET="CHANGE_ME_WITH_OPENSSL_RAND_HEX_32"
BETTER_AUTH_URL="http://localhost"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost"

# R2 or Spaces. R2 example:
# STORAGE_PROVIDER="Cloudflare R2"
# STORAGE_BUCKET="autoapplication-prod"
# STORAGE_REGION="auto"
# STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# STORAGE_FORCE_PATH_STYLE="false"
STORAGE_PROVIDER=""
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_FORCE_PATH_STYLE="false"

# Nightly DB backup retention in object storage.
DB_BACKUP_STORAGE_PREFIX="database-backups"
DB_BACKUP_RETENTION_DAYS="14"
DB_BACKUP_KEEP_LOCAL="0"
# Put large temporary dump files on an attached volume when available. The
# backup-runner service mounts this same directory at /backups.
DB_BACKUP_HOST_DIR="/mnt/HC_Volume_<id>/autoapplication/backups"
# Set to the old DB name only during migration if the source DB name differs.
# The current DigitalOcean database has commonly used "defaultdb".
DB_RESTORE_SOURCE_DATABASE_NAME=""

# AI and mail.
OPENAI_API_KEY=""
OPENAI_STANDARD_MODEL="gpt-4.1-mini"
OPENAI_REASONING_MODEL="gpt-5-mini"
OPENAI_FAST_MODEL="gpt-4o-mini"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Cron/route secrets.
INGESTION_CRON_SECRET=""
TRACKER_CRON_SECRET=""

# Source credentials and source flags. Copy real values from the old env.
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
USAJOBS_API_KEY=""
USAJOBS_EMAIL=""
COMPANIES_HOUSE_API_KEY=""
OPENCORPORATES_API_TOKEN=""
GITHUB_FRONTIER_TOKEN=""
GITHUB_FRONTIER_API_VERSION="2022-11-28"
SEC_FRONTIER_USER_AGENT="autoapplication/1.0 frontier-seed"

# Keep low-quality aggregators disabled unless explicitly testing them.
JOOBLE_API_KEY=""
JOOBLE_ENABLED="false"
SOURCE_JOOBLE_ENABLED="false"
INGEST_JOOBLE_ENABLED="false"
INGEST_ALLOW_JOOBLE="false"

ADZUNA_ENABLED="true"
JOBICY_ENABLED="true"
REMOTIVE_ENABLED="true"
THEMUSE_ENABLED="true"
USAJOBS_ENABLED="true"
WEWORKREMOTELY_ENABLED="true"

# Conservative defaults for one 4 vCPU / 8 GB VPS.
INGEST_GROWTH_MODE="0"
INGEST_SKIP_GENERIC_COMPANY_SITE_POLLS="true"
INGEST_CAPACITY_SCALE="1"
INGEST_SOURCE_POLL_CONCURRENCY="12"
INGEST_STEADY_DISCOVERY_LIMIT="20"
INGEST_STEADY_VALIDATION_LIMIT="40"
INGEST_STEADY_SOURCE_POLL_LIMIT="80"
INGEST_STEADY_REDISCOVERY_LIMIT="8"
INGEST_STEADY_URL_HEALTH_LIMIT="1"
INGEST_BURST_DISCOVERY_LIMIT="20"
INGEST_BURST_VALIDATION_LIMIT="40"
INGEST_BURST_SOURCE_POLL_LIMIT="120"
INGEST_BURST_REDISCOVERY_LIMIT="8"
INGEST_BURST_URL_HEALTH_LIMIT="1"
RECOVERY_WORKER_SOURCE_POLL_LIMIT="150"

# ATS/source tokens. Copy from old env or leave blank.
ADZUNA_COUNTRIES="ca,us"
ADZUNA_ALLOW_NON_NA="false"
ASHBY_ORG_TOKENS=""
GREENHOUSE_BOARD_TOKENS=""
HIMALAYAS_SOURCES="global"
ICIMS_PORTAL_TOKENS=""
JOBICY_TAGS=""
LEVER_SITE_TOKENS=""
RECRUITEE_COMPANY_TOKENS=""
RIPPLING_BOARD_TOKENS=""
SMARTRECRUITERS_COMPANY_TOKENS=""
SUCCESSFACTORS_DOMAIN_TOKENS=""
TALEO_SOURCE_TOKENS=""
THEMUSE_CATEGORIES=""
THEMUSE_LOCATIONS=""
USAJOBS_KEYWORDS=""
WORKABLE_ACCOUNT_TOKENS=""
WORKDAY_SOURCE_TOKENS=""
