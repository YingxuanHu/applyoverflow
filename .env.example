#
# Copy this file to `.env` for local development.
# Use `.env` rather than `.env.local` for values needed by Prisma and the CLI
# scripts in `package.json`, since many of them load env via `dotenv/config`.
#

# Core app / database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/autoapplication?schema=public"
DATABASE_URL_DO_PRIVATE=""
DATABASE_PREFER_PRIVATE_FOR_WORKERS="true"
DISABLE_INGEST_DAEMON="0"
LIFECYCLE_PROFILE="balanced"
APPLYOVERFLOW_WORKER_GROUPS="all"

# Optional Prisma pool caps by process role to keep the web app and workers
# from exhausting a small managed Postgres instance.
DATABASE_POOL_MAX_WEB=""
DATABASE_POOL_MAX_DAEMON=""
DATABASE_POOL_MAX_MAINTENANCE=""
DATABASE_POOL_MAX_RECOVERY_POLL=""
DATABASE_POOL_MAX_RECOVERY_VALIDATION=""
DATABASE_POOL_MAX_RECOVERY_DISCOVERY=""
DATABASE_POOL_MAX_BULK_RECOVERY=""
DATABASE_POOL_MAX_EXPANSION_PIPELINE=""

# Optional split web / worker deployment metadata for ops visibility
DO_WORKER_DROPLET_IPV4=""
DO_WORKER_DROPLET_PRIVATE_IPV4=""

# Better Auth
APP_NAME="ApplyOverflow"
APP_URL="http://localhost:3000"
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
# Production domain values:
# APP_URL="https://applyoverflow.com"
# BETTER_AUTH_URL="https://applyoverflow.com"
# NEXT_PUBLIC_BETTER_AUTH_URL="https://applyoverflow.com"
# Temporary only for HTTP/IP deployments. Keep false when using a real HTTPS domain.
AUTH_ALLOW_INSECURE_COOKIES="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma- or newline-separated user emails allowed to access /ops/* dashboards.
# Leave empty to deny ops dashboards to all signed-in users.
OPS_ADMIN_EMAILS=""

# OpenAI-backed AI features.
# Leave blank to disable resume parsing, fit analysis, and cover letter generation.
OPENAI_API_KEY=""
OPENAI_FAST_MODEL="gpt-5.4-nano"
OPENAI_STANDARD_MODEL="gpt-5.4-mini"
OPENAI_REASONING_MODEL="gpt-5.4"

# Optional salary filter FX provider. Defaults to open.er-api's USD feed and
# falls back to the checked-in rate table if unavailable.
SALARY_EXCHANGE_RATE_URL=""
SALARY_EXCHANGE_RATE_CACHE_MS=""

# Optional secret for POST /api/ingestion/schedule in production.
INGESTION_CRON_SECRET=""

# Optional secret for POST /api/tracker/deadline-reminders in production.
TRACKER_CRON_SECRET=""

ALLOW_DEMO_USER_FALLBACK="0"

# Optional SMTP delivery for auth mail and deadline reminders.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Optional S3-compatible document storage.
# DigitalOcean Spaces example:
# STORAGE_PROVIDER="DigitalOcean Spaces"
# STORAGE_BUCKET="applicationflow-documents"
# STORAGE_REGION="tor1"
# STORAGE_ENDPOINT="https://tor1.digitaloceanspaces.com"
STORAGE_PROVIDER=""
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_FORCE_PATH_STYLE="false"

# Optional database backup/restore to S3-compatible storage.
DB_BACKUP_STORAGE_PREFIX="database-backups"
DB_BACKUP_RETENTION_DAYS="14"
DB_BACKUP_KEEP_LOCAL="0"
DB_RESTORE_SOURCE_DATABASE_NAME=""

# Optional public API credentials
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
JOOBLE_API_KEY=""
USAJOBS_API_KEY=""
USAJOBS_EMAIL=""
COMPANIES_HOUSE_API_KEY=""
OPENCORPORATES_API_TOKEN=""
GITHUB_FRONTIER_TOKEN=""
GITHUB_FRONTIER_API_VERSION="2022-11-28"
SEC_FRONTIER_USER_AGENT="applyoverflow/1.0 frontier-seed"
SEC_EDGAR_EXCHANGES=""

# Optional source-family feature flags
ADZUNA_ENABLED="false"
JOBICY_ENABLED="true"
JOOBLE_ENABLED="false"
REMOTIVE_ENABLED="true"
THEMUSE_ENABLED="true"
USAJOBS_ENABLED="true"
WEWORKREMOTELY_ENABLED="true"

# Optional source / coverage overrides
ADZUNA_COUNTRIES="ca,us"
ADZUNA_ALLOW_NON_NA="false"
ADZUNA_SCHEDULE_PROFILES="techcore,specialist,discovery"
ASHBY_ORG_TOKENS=""
GREENHOUSE_BOARD_TOKENS=""
HIMALAYAS_SOURCES="global"
ICIMS_PORTAL_TOKENS=""
JOBICY_TAGS=""
JOOBLE_KEYWORDS=""
JOOBLE_LOCATIONS=""
JOOBLE_RESULTS_PER_PAGE=""
JOOBLE_MAX_PAGES=""
JOOBLE_SEARCHES_PER_RUN=""
JOOBLE_RATE_DELAY_MS=""
LEVER_SITE_TOKENS=""
RECRUITEE_COMPANY_TOKENS=""
RIPPLING_BOARD_TOKENS=""
SMARTRECRUITERS_COMPANY_TOKENS=""
SUCCESSFACTORS_DOMAIN_TOKENS=""
TALEO_SOURCE_TOKENS=""
THEMUSE_CATEGORIES=""
THEMUSE_LOCATIONS=""
USAJOBS_KEYWORDS=""
WORKABLE_ACCOUNT_TOKENS=""
WORKDAY_SOURCE_TOKENS=""

# Optional schedule overrides, in minutes
ADZUNA_SCHEDULE_MINUTES=""
ASHBY_SCHEDULE_MINUTES=""
GREENHOUSE_SCHEDULE_MINUTES=""
HIMALAYAS_SCHEDULE_MINUTES=""
ICIMS_SCHEDULE_MINUTES=""
JOBBANK_SCHEDULE_MINUTES=""
JOBICY_SCHEDULE_MINUTES=""
JOOBLE_SCHEDULE_MINUTES=""
LEVER_SCHEDULE_MINUTES=""
RECRUITEE_SCHEDULE_MINUTES=""
REMOTEOK_SCHEDULE_MINUTES=""
REMOTIVE_SCHEDULE_MINUTES=""
RIPPLING_SCHEDULE_MINUTES=""
SMARTRECRUITERS_SCHEDULE_MINUTES=""
SUCCESSFACTORS_SCHEDULE_MINUTES=""
TALEO_SCHEDULE_MINUTES=""
THEMUSE_SCHEDULE_MINUTES=""
USAJOBS_SCHEDULE_MINUTES=""
WORKABLE_SCHEDULE_MINUTES=""
WORKDAY_SCHEDULE_MINUTES=""

# Retention polling: keeps already-ingested jobs visibly alive. The feed hides
# jobs without source evidence in 14 days, so re-confirmation polls must never
# be starved by growth/novelty scheduling.
# Share of the poll admission budget reserved for sources nearing the evidence
# cliff (enqueue side), and share of each claim batch reserved for
# retention-stale sources (execution side).
INGEST_RETENTION_ADMISSION_BUDGET_RATIO="0.35"
INGEST_RETENTION_CLAIM_SHARE="0.4"
# Max PENDING URL_HEALTH tasks: enqueues stop at this ceiling so the liveness
# backlog stays a short working set the drain side can keep up with.
URL_HEALTH_PENDING_CEILING="6000"
# Minimum seconds between heavy poll-readiness reconciliation passes per
# process (claims re-check eligibility independently).
INGEST_READINESS_RECONCILE_MIN_INTERVAL_SECONDS="300"

# Automated source discovery lanes (slug probe + zombie sweep). Opt-in.
INGEST_AUTO_DISCOVERY_ENABLED="0"
SLUG_PROBE_REPAIR_LIMIT="300"
SLUG_PROBE_REPAIR_INTERVAL_SECONDS="21600"
SLUG_PROBE_COVERAGE_LIMIT="600"
SLUG_PROBE_COVERAGE_INTERVAL_SECONDS="43200"
SLUG_PROBE_CONCURRENCY="3"
ZOMBIE_SWEEP_LIMIT="500"
ZOMBIE_SWEEP_INTERVAL_SECONDS="43200"

# Source circuit breaker (persistent failers -> rediscovery; long-dead
# zombies retaining nothing -> disabled).
SOURCE_CIRCUIT_REDISCOVER_FAILURES="25"
SOURCE_CIRCUIT_REDISCOVER_STALE_DAYS="14"
SOURCE_CIRCUIT_DISABLE_FAILURES="100"
SOURCE_CIRCUIT_DISABLE_STALE_DAYS="30"

# Supply growth target used by `npm run supply:health`.
SUPPLY_TARGET_LIVE_JOBS="1000000"

# Optional growth-mode overrides for visible supply correction passes
INGEST_GROWTH_MODE="false"
INGEST_FRONTIER_POLL_ONLY="false"
INGEST_FEED_INDEX_REPAIR_LIMIT=""
INGEST_FEED_INDEX_REPAIR_CONCURRENCY=""
JOB_FEED_SUMMARY_REFRESH_SECONDS="300"
JOB_FEED_INDEX_SYNC_INITIAL_DELAY_SECONDS="120"
JOB_FEED_INDEX_SYNC_INTERVAL_SECONDS="1800"
JOB_FEED_INDEX_SYNC_TIMEOUT_SECONDS="300"
JOB_FEED_INDEX_SYNC_BATCH_SIZE="250"
JOB_FEED_INDEX_SYNC_MAX_BATCHES="4"
JOB_FEED_INDEX_SYNC_CONCURRENCY="2"
INGEST_GROWTH_FRONTIER_WINDOW_HOURS=""
INGEST_GROWTH_LOW_NOVELTY_RATIO_PERCENT=""
INGEST_GROWTH_LOW_NOVELTY_ACCEPTED_THRESHOLD=""
INGEST_GROWTH_FRONTIER_PRIORITY_BOOST=""
INGEST_GROWTH_NON_FRONTIER_PRIORITY_PENALTY=""
INGEST_GROWTH_REFRESH_HEAVY_PRIORITY_PENALTY=""
INGEST_GROWTH_HARD_COOLDOWN_HOURS=""
INGEST_GROWTH_SOURCE_QUERY_MULTIPLIER=""
